{
  "name": "rustyplayer",
  "version": "1.0.0",
  "description": "Video player with thumbnail gallery",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "video",
    "player",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.rustyplayer.app",
    "productName": "RustyPlayer",
    "directories": {
      "output": "dist"
    },
    "publish": null,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup.${ext}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
